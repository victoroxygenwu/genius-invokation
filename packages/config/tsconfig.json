{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "declaration": true,
    "emitDeclarationOnly": true,
    
    "useDefineForClassFields": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "./tsconfig.bun.json" }]
}
